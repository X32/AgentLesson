# 数据库配置
DB_HOST=localhost
DB_PORT=3306
DB_NAME=dailynews
DB_USER=root
DB_PASSWORD=your_password_here

# LLM API 配置
LLM_API_KEY=your_api_key_here
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL=qwen-plus

# Docker Hub 用户名（docker-compose.yml 中引用）
DOCKERHUB_USERNAME=your_dockerhub_username
